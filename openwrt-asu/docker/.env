REDIS_URL=redis://:<secret_value>@192.168.20.2:6379
PUBLIC_PATH=/volume5/storage/docker-data/openwrt-asu/data
CONFIG_PATH=/volume5/storage/docker-data/openwrt-asu/conf
BASE_CONTAINER=docker.io/openwrt/imagebuilder
REPOSITORY_ALLOW_LIST=["https://mirrors.ustc.edu.cn/openwrt","https://openwrt-download.czy21.com"]
ALLOW_DEFAULTS=1
LOG_LEVEL=INFO
CONTAINER_SOCKET_PATH=/run/user/1000/podman/podman.sock
BUILD_FAILURE_TTL=1m
JOB_TIMEOUT=1h